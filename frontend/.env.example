# =============================================================
# Bid6 Frontend — Environment Variables
# Copy this file to .env and fill in your values
# Vite exposes only variables prefixed with VITE_ to the browser
# =============================================================

# Backend socket server URL
# For local dev: http://localhost:3001
# For LAN testing: http://192.168.x.x:3001  (use your machine's local IP)
# Leave blank to auto-detect from window.location.hostname (recommended for LAN)
VITE_SOCKET_URL=http://localhost:3001

# App display name (shown in browser tab)
VITE_APP_NAME=Bid 6
